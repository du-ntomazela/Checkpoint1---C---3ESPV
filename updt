// Criando um loop com do while para menu de pedidos:
*/
using System.ComponentModel.DataAnnotations;

String MenuSelecionado;
int MenuSelecionadoInt;
String[] opcoes = { "Adicao", "Subtracao", "Multiplicacao", "Divisao", "Sair" };
do
{
    for (int opco = 0; opco < opcoes.Length; opco++)
    {
        Console.WriteLine($"{opco + 1} - {opcoes[opco]}");
    }
    Console.Write("Selecione uma das opções \n -->");
    MenuSelecionado = Console.ReadLine();
    if (int.TryParse(MenuSelecionado, out MenuSelecionadoInt))
    {
        Console.Write("Digite o primeiro numero \n -->");
        num1 = Console.ReadLine();
        Console.Write("Digite o segundo numero \n -->");
        num2 = Console.ReadLine();
        switch (MenuSelecionadoInt)
        {
            case 0:
                Console.Write($"O resultado da Soma {num1} + {num2} é igual a {num1 + num2}")
                break;
                
            case 1:
                Console.Write($"O resultado da Subtração {num1} - {num2} é igual a {num1 - num2}")
                break;
                
            case 2:
                Console.Write($"O resultado da Multiplicação {num1} X {num2} é igual a {num1 * num2}")
                break;
                
            case 3:
                if(num2 == 0){
                    Console.WirteLine(Não é possivel realizar divisões por 0! por favor informe o segundo numero sendo diferente de 0! )
                }else{
                    Console.Write($"O resultado da Divisão {num1} / {num2} é igual a {num1 / num2}")
                    break;
                }
                

        }
    }
    else {
        Console.WriteLine("Para acessar uma das funcionalidades é necessário digitar o ID referente ao módulo.");    
    }

} while (MenuSelecionadoInt != 4);
